# Required
BOT_TOKEN=123456:your-bot-token-from-@BotFather
OWNER_ID=123456789          # your numeric Telegram user id (@userinfobot)

# Optional
DB_PATH=data/bot.db         # SQLite database file
SHORT_FORM_WORDS=1          # how many leading words to shorten into the short form
CLEAN_SERVICE=1             # 1 = delete "X joined / left" service messages in groups
REVOKE_AFTER_JOIN=1         # 1 = revoke a /link invite once someone joins through it

# The message posted after /add. Placeholders: {amount} {account} {keyword}
#   {link} {order} {group} {short} {user} {name}
ADD_TEMPLATE=<b>Payment confirmed</b>
<blockquote>Order: {order}
Amount: {amount}
Account: {account}
Group: {group} ({short})</blockquote>
Your invite link (admin approval): {link}
