# ==========================================================================
# ChannelGuard admin bot (bot-token, aiogram). This is SEPARATE from the
# Telethon userbot in the repo root — it uses a BotFather token, not a login.
# Copy this file to bot/.env and fill it in.
# ==========================================================================

# BotFather token for the bot (https://t.me/BotFather -> /newbot).
BOT_TOKEN=123456:ABCDEF_your_bot_token_here

# The single owner: your numeric Telegram user id (get it from @userinfobot).
# Only this account can control the bot and receives every log/notification.
# The owner must press Start in the bot's DM once so it can message them.
OWNER_ID=123456789

# --------------------------------------------------------------------------
# Behaviour (optional)
# --------------------------------------------------------------------------
# Delete "X joined" / "X left" service messages in groups (needs Delete rights).
CLEAN_SERVICE=1
# After an approved user consumes a link, revoke it and mint a fresh one.
ROTATE_ON_JOIN=1
# Friendly name shown on the invite links the bot creates.
LINK_TITLE=ChannelGuard

# Prefix for order ids minted by /add (ANI0001, ANI0002, ...).
ORDER_PREFIX=ANI
# Optional chat to also post each /add order to. Numeric id (-100123456789)
# or a public @username. The bot must be an admin there. Empty = disabled.
PAYMENT_CHANNEL=

# Where to store the SQLite database (defaults to bot/data/channelguard.db).
# BOT_DB_PATH=bot/data/channelguard.db
