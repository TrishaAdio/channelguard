# ==========================================================================
# Telegram API credentials -> https://my.telegram.org  (API development tools)
# The userbot logs in as YOUR account. It must be an ADMIN of the channel with
# "Invite users via link" and "Ban users" rights.
# ==========================================================================
API_ID=1234567
API_HASH=your_api_hash_here

# ==========================================================================
# CHANNEL to guard. @username, a numeric id like -1001234567890, or invite link.
# (setup.py lets you pick it from a list.)
# ==========================================================================
CHANNEL=

# ==========================================================================
# OWNER who receives the rotating invite link. @username or numeric user id.
# The userbot must be able to DM this account (username, or shared chat).
# ==========================================================================
OWNER=

# ==========================================================================
# How often to revoke + reissue the invite link and DM it to the owner.
# ==========================================================================
ROTATE_MINUTES=5

# ==========================================================================
# Security sweep: kick all non-admin members on startup and every N minutes
# (catches anyone who joined while the guard was offline). 0 = startup-only.
# ==========================================================================
SWEEP_MINUTES=5

# ==========================================================================
# Quick-reply userbot (quickreply.py) — runs on the OWNER account.
# LINK_SOURCE = the guard account (username/id) whose messages carry the link.
#   blank = accept an invite link from any private chat.
# SHORTCUT = the Business quick reply name to keep equal to the link.
# ==========================================================================
LINK_SOURCE=
SHORTCUT=demo
# Send your current Business AWAY message to anyone who DMs the first time. 1/0.
GREET_NEW=1

# ==========================================================================
# Payment logger (quickreply.py). Reply to an image with  /add <amount> [name]
# to record a payment (INR) and auto-post the image to your post channel with
# a templated caption. Send  .help  for all commands and parameters.
# ==========================================================================
# Revenue split for the {rioshare}/{marco} caption parameters (should sum to 100).
RIO_PCT=55
MARCO_PCT=45
# {rioshare}/{marco} are computed from:
#   today       -> that % of the TOTAL amount received so far today
#   transaction -> that % of THIS single payment's amount
SHARE_BASE=today
# Timezone used to decide what counts as "today" (INR default = India).
TZ=Asia/Kolkata
# Caption parse mode for the auto-post: html or none.
PAY_PARSE_MODE=html
