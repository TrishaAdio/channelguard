# ==========================================================================
# Telegram API credentials -> https://my.telegram.org  (API development tools)
# The userbot logs in as YOUR account. It must be an ADMIN of the channel with
# "Invite users via link" and "Ban users" rights.
# ==========================================================================
API_ID=1234567
API_HASH=your_api_hash_here

# ==========================================================================
# CHANNEL to guard. @username, a numeric id like -1001234567890, or invite link.
# (setup.py lets you pick it from a list.)
# ==========================================================================
CHANNEL=

# ==========================================================================
# OWNER who receives the rotating invite link. @username or numeric user id.
# The userbot must be able to DM this account (username, or shared chat).
# ==========================================================================
OWNER=

# ==========================================================================
# How often to revoke + reissue the invite link and DM it to the owner.
# ==========================================================================
ROTATE_MINUTES=5

# ==========================================================================
# Quick-reply userbot (quickreply.py) — runs on the OWNER account.
# LINK_SOURCE = the guard account (username/id) whose messages carry the link.
#   blank = accept an invite link from any private chat.
# SHORTCUT = the Business quick reply name to keep equal to the link.
# ==========================================================================
LINK_SOURCE=
SHORTCUT=demo
# Also swap the link inside your Business AWAY message (if one is set). 1/0.
UPDATE_AWAY=1
